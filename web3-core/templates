    function testFuzz_Withdraw(uint256 amount) public {
        vm.assume(amount > 0 && amount < 100 ether);
        
        vm.prank(user);
        vault.deposit{value: amount}();
        
        vm.prank(user);
        vault.withdraw(amount);
        
        assertEq(address(vault).balance, 0);
    }
