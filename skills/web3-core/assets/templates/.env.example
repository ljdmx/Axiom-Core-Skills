# .env.example — Web3 Project Environment Variables Full Template
# Copy to .env and fill in real values; NEVER commit .env to Git!
# Add .env to .gitignore

# ═══════════════════════════════════════════════
# 🔑 Deployment Keys (For production, use a hardware wallet, not plaintext)
# ═══════════════════════════════════════════════
PRIVATE_KEY=0x...

# ═══════════════════════════════════════════════
# 🌐 RPC Nodes (Recommend Alchemy / Infura / QuickNode)
# ═══════════════════════════════════════════════
# Mainnets
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ZKSYNC_RPC_URL=https://mainnet.era.zksync.io
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
BNB_RPC_URL=https://bsc-dataseed.binance.org/

# Testnets
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ARB_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
OP_SEPOLIA_RPC_URL=https://opt-sepolia.g.alchemy.com/v2/YOUR_KEY

# ═══════════════════════════════════════════════
# 🔍 Blockchain Explorer APIs (Contract Verification)
# ═══════════════════════════════════════════════
ETHERSCAN_API_KEY=...
POLYGONSCAN_API_KEY=...
ARBISCAN_API_KEY=...
OPTIMISM_API_KEY=...
BASESCAN_API_KEY=...
SNOWTRACE_API_KEY=...
BSCSCAN_API_KEY=...

# ═══════════════════════════════════════════════
# 🛠️ Development Tools
# ═══════════════════════════════════════════════
# Gas Reporter
REPORT_GAS=true
CMC_API_KEY=...   # CoinMarketCap API (For Gas report USD conversion)

# OpenZeppelin Defender (Automated Deployment/Monitoring)
DEFENDER_API_KEY=...
DEFENDER_API_SECRET=...

# Tenderly (Debugging/Simulation)
TENDERLY_ACCESS_KEY=...
TENDERLY_PROJECT=...
TENDERLY_USERNAME=...

# ═══════════════════════════════════════════════
# 🌍 Frontend dApp (Use NEXT_PUBLIC_ prefix for Next.js)
# ═══════════════════════════════════════════════
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...   # https://cloud.walletconnect.com
NEXT_PUBLIC_ALCHEMY_API_KEY=...
NEXT_PUBLIC_CHAIN_ID=1                    # Default Chain ID

# ═══════════════════════════════════════════════
# 🗂️ Storage
# ═══════════════════════════════════════════════
PINATA_JWT=...        # IPFS Upload (https://app.pinata.cloud)
PINATA_GATEWAY=https://gateway.pinata.cloud
NFT_STORAGE_TOKEN=... # Backup IPFS

# The Graph
GRAPH_API_KEY=...

# ═══════════════════════════════════════════════
# 🏦 Account Abstraction
# ═══════════════════════════════════════════════
PIMLICO_API_KEY=...        # https://dashboard.pimlico.io
BICONOMY_PAYMASTER_KEY=...
STACKUP_API_KEY=...
