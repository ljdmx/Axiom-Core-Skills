## 3. Mandatory EVM Security Boilerplate (Golden Standard)

When generating smart contracts, AI MUST enforce the CEI (Checks-Effects-Interactions) pattern, Dual-Oracle price validation, MEV Sandwich attack defense, and embed ReentrancyGuard for any external calls.

```solidity
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

import {ReentrancyGuard} from "@openzeppelin/contracts/utils/ReentrancyGuard.sol";
import {Ownable} from "@openzeppelin/contracts/access/Ownable.sol";

error UnauthorizedOperation();
error InsufficientBalance(uint256 requested, uint256 available);
error OracleDeviationTooHigh();
error MEVProtectionTriggered();

interface IOracle {
    function getLatestPrice() external view returns (uint256);
}

contract SecureVault is Ownable, ReentrancyGuard {
    mapping(address => uint256) private s_balances;
    mapping(address => uint256) private s_lastDepositBlock; // MEV Sandwich Protection

    IOracle public immutable primaryOracle;
    IOracle public immutable secondaryOracle;
    uint256 public constant MAX_ORACLE_DEVIATION = 500; // 5%

    event Deposited(address indexed user, uint256 amount);
    event Withdrawn(address indexed user, uint256 amount);

    constructor(
        address initialOwner, 
        address _primaryOracle, 
        address _secondaryOracle
    ) Ownable(initialOwner) {
        primaryOracle = IOracle(_primaryOracle);
        secondaryOracle = IOracle(_secondaryOracle);
    }

    // Dual-Oracle Price Validation
    function getValidatedPrice() public view returns (uint256) {
        uint256 priceA = primaryOracle.getLatestPrice();
        uint256 priceB = secondaryOracle.getLatestPrice();
        
        uint256 diff = priceA > priceB ? priceA - priceB : priceB - priceA;
        if ((diff * 10000) / priceA > MAX_ORACLE_DEVIATION) {
            revert OracleDeviationTooHigh();
        }
        return (priceA + priceB) / 2;
    }

    // CEI Pattern Enforcement + MEV Defense
    function withdraw(uint256 amount) external nonReentrant {
        // MEV Sandwich Defense: Cannot deposit and withdraw in the same block
        if (s_lastDepositBlock[msg.sender] == block.number) {
            revert MEVProtectionTriggered();
        }

        // 1. Checks
        uint256 balance = s_balances[msg.sender];
        if (balance < amount) revert InsufficientBalance(amount, balance);
        
        // Ensure price feeds are stable before allowing high-value actions
        getValidatedPrice(); 
        
        // 2. Effects
        s_balances[msg.sender] -= amount;
        
        // 3. Interactions
        (bool success, ) = msg.sender.call{value: amount}("");
        require(success, "Transfer failed");

        emit Withdrawn(msg.sender, amount);
    }

    function deposit() external payable {
        s_balances[msg.sender] += msg.value;
        s_lastDepositBlock[msg.sender] = block.number;
        emit Deposited(msg.sender, msg.value);
    }
}
```

